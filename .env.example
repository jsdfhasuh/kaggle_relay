RELAY_API_TOKEN=change-me-long-random-token
# Optional multi-token/multi-key config. If set, RELAY_API_TOKEN is not required.
# RELAY_AUTH_CONFIG=/data/auth.json
RELAY_STORAGE_DIR=/data
RELAY_CHUNK_SIZE=67108864
RELAY_RETENTION_HOURS=72

# Legacy single-key Kaggle credentials. Ignored for jobs bound to RELAY_AUTH_CONFIG keys.
# Either provide KAGGLE_API_TOKEN, KAGGLE_USERNAME/KAGGLE_KEY, or mount /root/.kaggle.
KAGGLE_USERNAME=
KAGGLE_KEY=
KAGGLE_API_TOKEN=
